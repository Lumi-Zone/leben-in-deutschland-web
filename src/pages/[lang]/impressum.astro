---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getPath } from '../../utils/navigation';

export function getStaticPaths() {
  const supportedLangs = ['de', 'en', 'tr', 'ar', 'ua', 'ru', 'pl', 'fa', 'ps', 'ro', 'it', 'es'];
  return supportedLangs.map(lang => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props;
const legal = {
  providerName: 'Mehmet Karakaya',
  brand: 'Leben in Deutschland',
  street: '30625 Hannover',
  city: 'Deutschland',
  email: 'cfstechmobile@gmail.com',
  editorialResponsible: 'Mehmet Karakaya',
};
---

<Layout
  title="Impressum | Leben in Deutschland"
  description="Impressum und rechtliche Anbieterkennzeichnung der Plattform Leben in Deutschland."
  image="/logo.png"
  lang={lang}
>
  <Header lang={lang} />

  <main class="container mx-auto px-4 pb-12 pt-8 max-w-3xl">

    <h1 class="text-3xl font-bold mb-8">Impressum</h1>
    
    <div class="prose prose-blue max-w-none space-y-6 text-gray-700">
      <section>
        <h2 class="text-xl font-semibold text-gray-900">Angaben gemäß § 5 DDG</h2>
        <p>
          {legal.providerName}<br/>
          {legal.brand}<br/>
          {legal.street}<br/>
          {legal.city}
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900">Kontakt</h2>
        <p>
          E-Mail: <a href={`mailto:${legal.email}`}>{legal.email}</a>
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900">Verantwortlich für journalistisch-redaktionelle Inhalte (§ 18 Abs. 2 MStV)</h2>
        <p>
          {legal.editorialResponsible}<br/>
          {legal.street}<br/>
          {legal.city}
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900">Streitschlichtung</h2>
        <p>
          Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
          <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">
            https://ec.europa.eu/consumers/odr/
          </a>
        </p>
        <p>
          Wir sind nicht verpflichtet und nicht bereit, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900">Haftung für Inhalte und Links</h2>
        <p>
          Als Diensteanbieter sind wir nach den allgemeinen Gesetzen für eigene Inhalte auf diesen Seiten verantwortlich.
          Unser Angebot enthält außerdem Links zu externen Websites Dritter, auf deren Inhalte wir keinen Einfluss haben.
          Für diese fremden Inhalte übernehmen wir daher keine Gewähr.
        </p>
      </section>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200">
      <a href={getPath(`${lang}/`)} class="text-blue-600 hover:text-blue-800 font-medium">← Zurück zur Startseite</a>
    </div>
  </main>
</Layout>
