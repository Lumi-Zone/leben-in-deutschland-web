---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ProgressInsights from '../../components/ProgressInsights';
import StudyHabitCard from '../../components/StudyHabitCard';
import questions from '../../data/questions.json';
import { useTranslations } from '../../i18n/ui';
import { getPath } from '../../utils/navigation';

type SupportedLang = 'de' | 'en' | 'tr' | 'ar' | 'ua' | 'ru' | 'pl' | 'fa' | 'ps' | 'ro' | 'it' | 'es';

export function getStaticPaths() {
  const supportedLangs: SupportedLang[] = ['de', 'en', 'tr', 'ar', 'ua', 'ru', 'pl', 'fa', 'ps', 'ro', 'it', 'es'];
  return supportedLangs.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props as { lang: SupportedLang };
const t = useTranslations(lang);
---

<Layout
  title={`${t("progress.page_title")} - ${t("hero.title")}`}
  description={t("progress.subtitle")}
  image="/logo.png"
  lang={lang}
>
  <Header lang={lang} />

  <main class="container mx-auto px-4 py-10 min-h-screen bg-gray-50">
    <div class="max-w-5xl mx-auto mb-8">
      <a href={getPath(`${lang}/`)} class="text-blue-600 hover:text-blue-800 font-medium">← {t("question.back")}</a>
    </div>

    <section class="max-w-5xl mx-auto mb-6">
      <div class="rounded-3xl border border-cyan-100 bg-gradient-to-br from-cyan-50 via-white to-blue-50 shadow-sm p-6 md:p-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-1">{t("progress.focus_title")}</h2>
          <p class="text-gray-600">{t("progress.focus_subtitle")}</p>
        </div>
        <a
          href={getPath(`${lang}/focus`)}
          class="inline-flex items-center justify-center px-5 py-3 rounded-xl bg-cyan-600 text-white font-semibold hover:bg-cyan-700 transition-colors"
        >
          {t("progress.focus_cta")}
        </a>
      </div>
    </section>

    <StudyHabitCard
      client:visible
      labels={{
        title: t("progress.habit_title"),
        subtitle: t("progress.habit_subtitle"),
        todayAttempts: t("progress.habit_today_attempts"),
        dailyGoal: t("progress.habit_daily_goal"),
        currentStreak: t("progress.habit_current_streak"),
        bestStreak: t("progress.habit_best_streak"),
        goalMet: t("progress.habit_goal_met"),
        goalRemaining: t("progress.habit_goal_remaining"),
        setGoal: t("progress.habit_set_goal"),
        days: t("progress.habit_days"),
        attempts: t("progress.habit_attempts"),
        quick5: t("progress.habit_quick_5"),
        quick10: t("progress.habit_quick_10"),
        quick20: t("progress.habit_quick_20"),
      }}
    />

    <ProgressInsights
      client:visible
      lang={lang}
      totalQuestions={questions.length}
      questionMeta={questions.map((question) => ({
        id: question.id,
        areaCode: question.area_code,
      }))}
      labels={{
        title: t("progress.title"),
        subtitle: t("progress.subtitle"),
        metricSolved: t("progress.metric_solved"),
        metricAttempts: t("progress.metric_attempts"),
        metricAccuracy: t("progress.metric_accuracy"),
        metricFavorites: t("progress.metric_favorites"),
        lastActivity: t("progress.last_activity"),
        lastActivityNever: t("progress.last_activity_never"),
        weakTitle: t("progress.weak_title"),
        weakEmpty: t("progress.weak_empty"),
        openQuestion: t("progress.open_question"),
        clearStats: t("progress.clear_stats"),
        attemptsShort: t("progress.attempts_short"),
        wrongShort: t("progress.wrong_short"),
        topicTitle: t("progress.topic_title"),
        topicSubtitle: t("progress.topic_subtitle"),
        topicSolved: t("progress.topic_solved"),
        topicAttempts: t("progress.topic_attempts"),
        topicAccuracy: t("progress.topic_accuracy"),
        topicPolitik: t("progress.topic_politik"),
        topicGeschichte: t("progress.topic_geschichte"),
        topicGesellschaft: t("progress.topic_gesellschaft"),
        topicLand: t("progress.topic_land"),
      }}
    />
  </main>
</Layout>
