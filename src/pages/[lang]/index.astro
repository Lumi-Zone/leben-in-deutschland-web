---
import Layout from '../../layouts/Layout.astro';
import questions from '../../data/questions.json';
import { useTranslations } from '../../i18n/ui';
import PhoneSlider from '../../components/PhoneSlider';
import ReviewsSlider from '../../components/ReviewsSlider';
import FeatureCarousel from '../../components/FeatureCarousel';
import ContinueLearningCard from '../../components/ContinueLearningCard';
import { getReviews } from '../../data/reviews';
import { getCollection } from 'astro:content';
import { getBlogImageAlt, resolveBlogImage } from '../../utils/blog';

export function getStaticPaths() {
  const supportedLangs = ['de', 'en', 'tr', 'ar', 'ua', 'ru', 'pl', 'fa', 'ps', 'ro', 'it', 'es'];
  return supportedLangs.map(lang => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
import Header from '../../components/Header.astro';
import { getPath } from '../../utils/navigation';

const featureItems = [
    {
        title: t("features.learn.title"),
        description: t("features.learn.desc"),
        image: getPath('mockups/m5.png'),
    },
    {
        title: t("features.practice.title"),
        description: t("features.practice.desc"),
        image: getPath('mockups/m6.png'),
    },
    {
        title: t("features.exam.title"),
        description: t("features.exam.desc"),
        image: getPath('mockups/m4.png'),
    },
];

const reviewsData = getReviews(lang as string);
const heroDescription = t("hero.subtitle").replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const blogPosts = await getCollection('blog');
const recentBlogPosts = blogPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3)
	.map((post) => ({
		...post,
		image: resolveBlogImage(post),
		imageAlt: getBlogImageAlt(post.data.title),
	}));
const stateLinks = [
	{ slug: 'baden-wuerttemberg', label: 'Baden-Württemberg' },
	{ slug: 'bayern', label: 'Bayern' },
	{ slug: 'berlin', label: 'Berlin' },
	{ slug: 'brandenburg', label: 'Brandenburg' },
	{ slug: 'bremen', label: 'Bremen' },
	{ slug: 'hamburg', label: 'Hamburg' },
	{ slug: 'hessen', label: 'Hessen' },
	{ slug: 'mecklenburg-vorpommern', label: 'Mecklenburg-Vorpommern' },
	{ slug: 'niedersachsen', label: 'Niedersachsen' },
	{ slug: 'nordrhein-westfalen', label: 'Nordrhein-Westfalen' },
	{ slug: 'rheinland-pfalz', label: 'Rheinland-Pfalz' },
	{ slug: 'saarland', label: 'Saarland' },
	{ slug: 'sachsen', label: 'Sachsen' },
	{ slug: 'sachsen-anhalt', label: 'Sachsen-Anhalt' },
	{ slug: 'schleswig-holstein', label: 'Schleswig-Holstein' },
	{ slug: 'thueringen', label: 'Thüringen' },
];
---

<Layout
	title={`${t("hero.title")} - Master the Exam`}
	description={heroDescription}
	image="/logo.png"
	lang={lang}
>
	<!-- Navigation -->
	<Header lang={lang} />

	<main>
		<!-- HERO SECTION -->
		<div class="container mx-auto px-4 py-10 lg:py-14 text-center relative">
			<div class="absolute inset-x-4 top-8 h-44 bg-gradient-to-r from-blue-100/45 via-transparent to-amber-100/45 blur-3xl pointer-events-none" aria-hidden="true"></div>
			<div class="inline-flex items-center gap-3 bg-yellow-50 border border-yellow-200 px-6 py-2.5 rounded-full mb-7 shadow-sm transition-transform hover:scale-105 cursor-default">
				<span class="text-sm font-bold uppercase tracking-widest text-yellow-900">{t("hero.badge")}</span>
				<div class="flex text-yellow-500 text-base">★★★★★</div>
				<span class="text-base font-extrabold text-gray-900">4.8</span>
			</div>
			
			<h1 class="text-5xl lg:text-7xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-gray-900 to-gray-600 mb-6 tracking-tight">
				{t("hero.title")}
			</h1>
			
			<p class="text-xl text-gray-600 max-w-2xl mx-auto mb-7 leading-relaxed" set:html={t("hero.subtitle")}>
			</p>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12 lg:mb-14">
				<a href="https://apps.apple.com/app/leben-in-deutschland-2026/id6723899981" class="bg-black text-white px-6 py-3 rounded-xl flex items-center gap-3 hover:bg-gray-800 transition-all transform hover:scale-105 shadow-xl border border-gray-800 group">
					<svg class="w-8 h-8 group-hover:opacity-90 transition-opacity" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M16.365 1.43c0 1.14-.41 1.99-1.01 2.72-.63.77-1.66 1.36-2.67 1.28-.13-1.06.3-2.06.9-2.75.62-.71 1.7-1.22 2.78-1.25zM19.46 17.03c-.41.94-.61 1.36-1.14 2.21-.74 1.19-1.78 2.67-3.07 2.68-1.15.01-1.45-.75-3.01-.74-1.56.01-1.89.75-3.03.74-1.29-.01-2.29-1.34-3.03-2.53-2.07-3.35-2.28-7.28-1.01-9.24.9-1.39 2.33-2.2 3.67-2.2 1.37 0 2.23.76 3.37.76 1.11 0 1.78-.76 3.36-.76 1.2 0 2.47.65 3.37 1.78-2.96 1.62-2.47 5.85.52 7.3z"/>
					</svg>
					<div class="text-left">
						<div class="text-[10px] font-medium opacity-80 uppercase leading-none mb-1">{t("hero.download_apple")}</div>
						<div class="text-lg font-bold leading-none -mt-0.5 font-sans">App Store</div>
					</div>
				</a>
				<a href="https://play.google.com/store/apps/details?id=com.einbuergerungapp" class="bg-black text-white px-6 py-3 rounded-xl flex items-center gap-3 hover:bg-gray-800 transition-all transform hover:scale-105 shadow-xl border border-gray-800 group">
					<svg class="w-7 h-7 group-hover:opacity-90 transition-opacity" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path d="M3 2.5L14.5 12L3 21.5V2.5Z" fill="white"/>
						<path d="M14.5 12L18.2 8.9L21 10.5C21.7 10.9 21.7 11.9 21 12.3L18.2 13.9L14.5 12Z" fill="white" fill-opacity="0.85"/>
						<path d="M14.5 12L18.2 15.1L8.3 20.7L3 21.5L14.5 12Z" fill="white" fill-opacity="0.72"/>
						<path d="M14.5 12L8.3 3.3L3 2.5L14.5 12Z" fill="white" fill-opacity="0.62"/>
					</svg>
					<div class="text-left">
						<div class="text-[10px] font-medium opacity-80 uppercase leading-none mb-1">{t("hero.download_google")}</div>
						<div class="text-lg font-bold leading-none -mt-0.5 font-sans">Google Play</div>
					</div>
				</a>
			</div>

			<!-- Phone Mockup Carousel -->
			<!-- Phone Mockup Carousel -->
			<div class="mb-12 lg:mb-14">
				<PhoneSlider client:visible />
			</div>
    </div>
    
    <!-- Feature Cards -->
    <section id="features" class="scroll-mt-24 mb-10 md:mb-12">
      <div class="container mx-auto px-4 text-center">
				<div class="bg-black text-white text-xs font-bold px-4 py-2 rounded-full inline-block mb-6 uppercase tracking-widest">{t("features.badge")}</div>
				<h2 class="text-4xl font-bold text-gray-900 mb-8 md:mb-10 max-w-2xl mx-auto">{t("features.title")}</h2>
				
				<FeatureCarousel client:visible items={featureItems} />
			</div>
		</section>

		<!-- REVIEWS SECTION -->
		<ReviewsSlider client:visible lang={lang} reviewsData={reviewsData} />

        <ContinueLearningCard
            client:visible
            lang={lang}
            totalQuestions={questions.length}
            labels={{
                title: t("home.continue_title"),
                subtitle: t("home.continue_subtitle"),
                continueCta: t("home.continue_cta"),
                startCta: t("home.continue_start"),
                solvedLabel: t("home.continue_solved"),
                lastLabel: t("home.continue_last"),
                noProgress: t("home.continue_no_progress"),
            }}
        />

		<section class="py-14 md:py-16">
			<div class="container mx-auto px-4">
				<div class="rounded-3xl border border-blue-100 bg-gradient-to-b from-blue-50/70 to-white p-6 md:p-8 shadow-sm">
					<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
						<h3 class="text-2xl md:text-3xl font-bold text-gray-900">
							{t("progress.topic_land")} · 16
						</h3>
						<a href={getPath(`${lang}/berlin-fragen`)} class="inline-flex items-center w-fit px-4 py-2 rounded-xl border border-blue-200 text-blue-700 bg-blue-50 hover:bg-blue-100 transition-colors font-semibold">
							{t("home.start_quiz")} →
						</a>
					</div>
					<div class="grid grid-cols-2 md:grid-cols-4 gap-3">
						{stateLinks.map((state) => (
							<a
								href={getPath(`${lang}/${state.slug}-fragen`)}
								class="group rounded-xl border border-white/80 bg-white/85 px-3.5 py-3 text-sm font-medium text-gray-700 hover:text-blue-700 hover:border-blue-200 hover:bg-blue-50/70 transition-all shadow-[0_8px_20px_-18px_rgba(15,23,42,0.5)]"
							>
								<span class="inline-flex items-center gap-1.5">
									<span class="text-blue-300 group-hover:text-blue-500 transition-colors">•</span>
									{state.label}
								</span>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="pb-14 md:pb-16">
			<div class="container mx-auto px-4">
				<div class="flex items-center justify-between mb-6 gap-4">
					<div>
						<h3 class="text-2xl md:text-3xl font-bold text-gray-900">{t("blog.title")}</h3>
						<p class="text-sm md:text-base text-gray-600 mt-1">{t("blog.subtitle")}</p>
					</div>
					<a
						href={getPath(`${lang}/blog`)}
						class="inline-flex items-center rounded-xl border border-blue-200 bg-blue-50 px-4 py-2.5 text-sm font-semibold text-blue-700 hover:bg-blue-100 transition-colors"
					>
						{t("nav.blog")} →
					</a>
				</div>

					<div class="grid gap-4 md:grid-cols-3">
						{recentBlogPosts.map((post) => (
							<article class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm hover:shadow-md transition-shadow h-full flex flex-col">
								<div class="h-36 rounded-xl overflow-hidden bg-slate-100 mb-4">
									<img src={post.image} alt={post.imageAlt} loading="lazy" decoding="async" class="h-full w-full object-cover" />
								</div>
								<div class="text-xs text-gray-500 mb-2">{post.data.pubDate.toLocaleDateString(lang)}</div>
								<h4 class="text-lg font-bold text-gray-900 mb-2 line-clamp-2">{post.data.title}</h4>
								<p class="text-sm text-gray-600 line-clamp-3 mb-4 flex-1">{post.data.description}</p>
							<a
								href={getPath(`${lang}/blog/${post.slug}`)}
								class="inline-flex items-center text-sm font-semibold text-blue-700 hover:underline"
							>
								{t("blog.read_more")}
							</a>
						</article>
					))}
				</div>
			</div>
		</section>

        <!-- SAMPLE QUESTIONS SECTION -->
        <section class="py-20">
            <div class="container mx-auto px-4 text-center">
                <h3 class="text-2xl font-bold mb-8">{t("home.sample_questions")} ({questions.length})</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
                    {questions.slice(0, 6).map((q) => {
                            const qTitle = (q as any)[`q_${lang}`] || q.q_de;
                            return (
                            <a href={getPath(`${lang}/frage/${q.id}`)} class="block group">
                                <div class="bg-white p-5 rounded-xl border border-gray-100 hover:border-blue-500 hover:shadow-lg transition-all h-full flex flex-col group-hover:-translate-y-1">
                                    <div class="flex items-center justify-between mb-3">
                                        <span class="text-xs font-bold text-blue-600 bg-blue-50 px-2.5 py-1 rounded-md">#{q.id}</span>
                                        <span class="text-[10px] font-semibold text-gray-500 uppercase tracking-wide bg-gray-50 px-2 py-1 rounded">{q.area}</span>
                                    </div>
                                    <h2 class="text-base font-medium text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-3 leading-relaxed">
                                        {qTitle}
                                    </h2>
                                </div>
                            </a>
                            );
                    })}
                </div>
                    <div class="mt-8 flex flex-col sm:flex-row justify-center items-center gap-3">
                        <a href={getPath(`${lang}/frage/1`)} class="inline-flex items-center px-5 py-2.5 rounded-xl border border-blue-200 text-blue-700 bg-blue-50 hover:bg-blue-100 font-semibold transition-colors">
                            {t("home.start_quiz")} →
                        </a>
                        <a href={getPath(`${lang}/exam`)} class="inline-flex items-center px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-semibold transition-colors shadow-sm">
                            {t("home.start_exam")}
                        </a>
                        <a href={getPath(`${lang}/favorites`)} class="inline-flex items-center px-5 py-2.5 rounded-xl border border-amber-200 text-amber-700 bg-amber-50 hover:bg-amber-100 font-semibold transition-colors">
                            {t("home.favorites_cta")}
                        </a>
                        <a href={getPath(`${lang}/progress`)} class="inline-flex items-center px-5 py-2.5 rounded-xl border border-emerald-200 text-emerald-700 bg-emerald-50 hover:bg-emerald-100 font-semibold transition-colors">
                            {t("home.progress_cta")}
                        </a>
                    </div>
            </div>
        </section>

		<!-- FOOTER -->
		<footer class="bg-white border-t border-gray-100 py-12">
			<div class="container mx-auto px-4 text-center">
				<div class="flex flex-col md:flex-row justify-center items-center gap-8 text-sm text-gray-500 mb-8">
					<a href={getPath(`${lang}/terms-of-service`)} class="hover:text-black transition-colors">{t("nav.tos")}</a>
					<a href={getPath(`${lang}/datenschutz`)} class="hover:text-black transition-colors">{t("nav.privacy")}</a>
					<a href={getPath(`${lang}/impressum`)} class="hover:text-black transition-colors">{t("nav.imprint")}</a>
					<a href={getPath(`${lang}/subscription-terms`)} class="hover:text-black transition-colors">{t("nav.subscription")}</a>
					<a href={getPath(`${lang}/blog`)} class="hover:text-black transition-colors font-semibold text-blue-600">{t("nav.blog")}</a>
					<a href={getPath(`${lang}/support`)} class="hover:text-black transition-colors">{t("nav.support")}</a>
                    <a href="https://x.com/300Fragen" target="_blank" rel="noopener noreferrer" class="hover:text-black transition-colors flex items-center gap-1">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        {t("social.follow")}
                    </a>
				</div>
				<p class="text-xs text-gray-400">&copy; {new Date().getFullYear()} Leben in Deutschland. {t("footer.rights")}</p>
			</div>
		</footer>

	</main>
</Layout>
