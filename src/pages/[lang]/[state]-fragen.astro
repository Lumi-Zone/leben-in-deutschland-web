---
import Layout from '../../layouts/Layout.astro';
import questions from '../../data/questions.json';
import { useTranslations } from '../../i18n/ui';
import StateQuestionExplorer from '../../components/StateQuestionExplorer';

type SupportedLang = 'de' | 'en' | 'tr' | 'ar' | 'ua' | 'ru' | 'pl' | 'fa' | 'ps' | 'ro' | 'it' | 'es';
type QuestionItem = (typeof questions)[number];

interface StateQuestionsProps {
  stateName: string;
  questions: QuestionItem[];
  lang: SupportedLang;
}

export function getStaticPaths() {
  const supportedLangs: SupportedLang[] = ['de', 'en', 'tr', 'ar', 'ua', 'ru', 'pl', 'fa', 'ps', 'ro', 'it', 'es'];

  const states = [
    'Baden-Württemberg', 'Bayern', 'Berlin', 'Brandenburg', 'Bremen', 
    'Hamburg', 'Hessen', 'Mecklenburg-Vorpommern', 'Niedersachsen', 
    'Nordrhein-Westfalen', 'Rheinland-Pfalz', 'Saarland', 'Sachsen', 
    'Sachsen-Anhalt', 'Schleswig-Holstein', 'Thüringen'
  ];

  const paths: Array<{
    params: { lang: SupportedLang; state: string };
    props: StateQuestionsProps;
  }> = [];

  supportedLangs.forEach((lang) => {
    states.forEach((state) => {
        // Slugify state name for URL
        const slug = state.toLowerCase()
        .replace(/ü/g, 'ue')
        .replace(/ö/g, 'oe')
        .replace(/ä/g, 'ae')
        .replace(/ß/g, 'ss')
        .replace(/\s+/g, '-');

        const stateQuestions = questions.filter(q => q.area_code === 'land' && q.thema === state);

        paths.push({
            params: { lang, state: slug },
            props: { stateName: state, questions: stateQuestions, lang },
        });
    });
  });
  
  return paths;
}

const { stateName, questions: stateQuestions, lang } = Astro.props as StateQuestionsProps;
const t = useTranslations(lang);
import Header from '../../components/Header.astro';
import { getPath } from '../../utils/navigation';
---

<Layout
  title={`Leben in Deutschland - ${stateName} Fragen`}
  description={`${stateName}: Offizielle Bundesland-Fragen für den Einbürgerungstest und Leben in Deutschland.`}
  image="/logo.png"
  lang={lang}
>
  <Header lang={lang} />
  <main class="container mx-auto px-4 py-12">
    <div class="mb-8">
      <a href={getPath(`${lang}/`)} class="text-blue-600 hover:text-blue-800 font-medium">← {t("question.back")}</a>
    </div>

    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">{stateName}</h1>
      <p class="text-gray-600 max-w-2xl mx-auto">
        {t("home.sample_questions")}
      </p>
    </div>

    <StateQuestionExplorer
      client:visible
      lang={lang}
      stateName={stateName}
      questions={stateQuestions}
      labels={{
        searchPlaceholder: t("state.search_placeholder"),
        searchAriaLabel: t("state.search_label"),
        sortLabel: t("state.sort_label"),
        sortDefault: t("state.sort_default"),
        sortIdAsc: t("state.sort_id_asc"),
        sortIdDesc: t("state.sort_id_desc"),
        viewLabel: t("state.view_label"),
        viewGrid: t("state.view_grid"),
        viewList: t("state.view_list"),
        clearSearch: t("state.clear"),
        results: t("state.results"),
        emptyTitle: t("state.empty_title"),
        emptySubtitle: t("state.empty_subtitle"),
      }}
    />
  </main>
</Layout>
